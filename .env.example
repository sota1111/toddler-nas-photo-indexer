DATABASE_URL=sqlite:///./data/media.db

# Auth
AUTH_USERNAME=admin
# Cloud Run本番環境ではSecret Manager管理 (secret name: nas-indexer-auth-password)
AUTH_PASSWORD=changeme
# Cloud Run本番環境ではSecret Manager管理 (secret name: nas-indexer-auth-secret-key)
AUTH_SECRET_KEY=your_secret_key_at_least_32_chars

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=toddler-nas-photo-indexer-backend
ARTIFACT_REGISTRY_REPOSITORY=toddler-nas-registry
IMAGE_NAME=toddler-nas-photo-indexer-backend
