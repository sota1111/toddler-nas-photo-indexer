DATABASE_URL=sqlite:///./data/media.db

# ===================================
# Frontend (Firebase Client SDK)
# ===================================
# Firebaseクライアント側でのサインイン（ID Token取得）に使用
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id

# ===================================
# Backend (Session Validation)
# ===================================
# ログインを許可するメールアドレス（カンマ区切り）
ALLOWED_USER_EMAILS=your-email@example.com
# セッションCookie (auth_token) の署名用シークレット
AUTH_SECRET=your-random-secret-key-here
# ID Token検証に使用するGoogle CloudプロジェクトID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# 許可するオリジン（フロントエンドのURL）
CORS_ORIGINS=http://localhost:5173

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=toddler-nas-photo-indexer-backend
ARTIFACT_REGISTRY_REPOSITORY=toddler-nas-registry
IMAGE_NAME=toddler-nas-photo-indexer-backend
